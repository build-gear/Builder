# Builder Gear macOS internal distribution environment.
# Copy to a local ignored file, fill with real values, then pass it to release commands.
#
# Example:
#   cp release/macos.internal.env.example release/macos.internal.env
#   ${EDITOR:-vi} release/macos.internal.env
#   pnpm release:preflight -- --platform macos --channel internal --env-file release/macos.internal.env
#   pnpm release:check:distribution -- --platform macos --env-file release/macos.internal.env

# Developer ID Application identity as shown by:
#   security find-identity -v -p codesigning
APPLE_SIGNING_IDENTITY="<DEVELOPER_ID_APPLICATION_IDENTITY>"

# GitHub release-candidate runners import this base64-encoded .p12 into
# an ephemeral keychain before running the same distribution gate. Local
# builds can leave these unset when the identity is already in your keychain.
APPLE_CERTIFICATE="<BASE64_ENCODED_DEVELOPER_ID_APPLICATION_P12>"
APPLE_CERTIFICATE_PASSWORD="<APPLE_CERTIFICATE_P12_PASSWORD>"
APPLE_KEYCHAIN_PASSWORD="<TEMPORARY_CI_KEYCHAIN_PASSWORD>"

# Apple notarization credentials. Use an app-specific password or a CI secret.
APPLE_ID="<APPLE_ID_EMAIL>"
APPLE_PASSWORD="<APPLE_APP_SPECIFIC_PASSWORD_OR_KEYCHAIN_PROFILE>"
APPLE_TEAM_ID="<APPLE_TEAM_ID>"
