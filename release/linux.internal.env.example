# Builder Gear Linux internal distribution environment.
# Linux internal release packaging does not require signing environment variables.
#
# Example:
#   cp release/linux.internal.env.example release/linux.internal.env
#   pnpm release:preflight -- --platform linux --channel internal --env-file release/linux.internal.env
#   pnpm release:check:distribution -- --platform linux --env-file release/linux.internal.env
