# Builder Gear Windows internal distribution environment.
# Copy to a local ignored file, fill with real values, then pass it to release commands.
#
# Example:
#   copy release\windows.internal.env.example release\windows.internal.env
#   pnpm release:preflight -- --platform windows --channel internal --env-file release/windows.internal.env
#   pnpm release:check:distribution -- --platform windows --env-file release/windows.internal.env

# Authenticode certificate material. Use a certificate file path or base64:<pfx-content>.
WINDOWS_SIGNING_CERTIFICATE="<WINDOWS_PFX_FILE_OR_BASE64_PFX>"
WINDOWS_SIGNING_PASSWORD="<WINDOWS_PFX_PASSWORD>"
