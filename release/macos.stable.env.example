# Builder Gear macOS stable release environment.
# Copy to a local ignored file, fill with real values, then pass it to release commands.
#
# Example:
#   cp release/macos.stable.env.example release/macos.stable.env
#   ${EDITOR:-vi} release/macos.stable.env
#   pnpm release:preflight -- --platform macos --channel stable --env-file release/macos.stable.env
#   pnpm release:check:stable -- --platform macos --env-file release/macos.stable.env

# macOS signing and notarization.
APPLE_SIGNING_IDENTITY="<DEVELOPER_ID_APPLICATION_IDENTITY>"
APPLE_CERTIFICATE="<BASE64_ENCODED_DEVELOPER_ID_APPLICATION_P12>"
APPLE_CERTIFICATE_PASSWORD="<APPLE_CERTIFICATE_P12_PASSWORD>"
APPLE_KEYCHAIN_PASSWORD="<TEMPORARY_CI_KEYCHAIN_PASSWORD>"
APPLE_ID="<APPLE_ID_EMAIL>"
APPLE_PASSWORD="<APPLE_APP_SPECIFIC_PASSWORD_OR_KEYCHAIN_PROFILE>"
APPLE_TEAM_ID="<APPLE_TEAM_ID>"

# Tauri updater signing.
# Accepts a private key file path, raw private-key content, or base64:<encoded-key-content>.
TAURI_SIGNING_PRIVATE_KEY="<TAURI_UPDATER_PRIVATE_KEY_FILE_OR_CONTENT>"
TAURI_SIGNING_PRIVATE_KEY_PASSWORD="<TAURI_UPDATER_PRIVATE_KEY_PASSWORD>"

# Tauri updater runtime config injected into the generated stable config.
# The public key must be public key content, not a file path.
BUILDER_GEAR_UPDATER_PUBKEY="<TAURI_UPDATER_PUBLIC_KEY_CONTENT>"
BUILDER_GEAR_UPDATE_ENDPOINT="<PRODUCTION_HTTPS_STATIC_UPDATER_JSON_URL>"
