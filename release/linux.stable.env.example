# Builder Gear Linux stable release environment.
# Copy to a local ignored file, fill with real values, then pass it to release commands.
#
# Example:
#   cp release/linux.stable.env.example release/linux.stable.env
#   ${EDITOR:-vi} release/linux.stable.env
#   pnpm release:preflight -- --platform linux --channel stable --env-file release/linux.stable.env
#   pnpm release:check:stable -- --platform linux --env-file release/linux.stable.env

# Tauri updater signing.
# Accepts a private key file path, raw private-key content, or base64:<encoded-key-content>.
TAURI_SIGNING_PRIVATE_KEY="<TAURI_UPDATER_PRIVATE_KEY_FILE_OR_CONTENT>"
TAURI_SIGNING_PRIVATE_KEY_PASSWORD="<TAURI_UPDATER_PRIVATE_KEY_PASSWORD>"

# Tauri updater runtime config injected into the generated stable config.
# The public key must be public key content, not a file path.
BUILDER_GEAR_UPDATER_PUBKEY="<TAURI_UPDATER_PUBLIC_KEY_CONTENT>"
BUILDER_GEAR_UPDATE_ENDPOINT="<PRODUCTION_HTTPS_STATIC_UPDATER_JSON_URL>"
